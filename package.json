{
  "name": "clswind",
  "version": "26.12.4",
  "description": "A lightweight utility to conditionally join Tailwind CSS classes without conflicts. Stop copy-pasting `cn` helper functions.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build",
    "lint": "tsc",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "classnames",
    "css",
    "tailwindcss",
    "clsx",
    "tailwind-merge",
    "cn",
    "utility",
    "helper",
    "react",
    "vue",
    "svelte",
    "nextjs",
    "shadcn-ui"
  ],
  "author": "iubns",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iubns/clswind.git"
  },
  "bugs": {
    "url": "https://github.com/iubns/clswind/issues"
  },
  "homepage": "https://github.com/iubns/clswind#readme",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  }
}
